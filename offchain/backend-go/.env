# Environment Variables for Backend (Golang)

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=8080
ENV=development
CONFIG_PATH=../config/config.yaml

# development | staging | production

# ==========================================
# DATABASE - MONGODB
# ==========================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=vndc_db
MONGODB_USER=vndc_app
MONGODB_PASSWORD=strong_password_here
MONGODB_TIMEOUT=10s

# ==========================================
# CACHE - REDIS
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=100

# ==========================================
# BLOCKCHAIN - SMART CONTRACTS
# ==========================================

# Token Contract (VNDC ERC20)
VNDC_TOKEN_ADDRESS=0x...
VNDC_TOKEN_DECIMALS=18

# NFT Contract (ERC1155)
VNDC_NFT_ADDRESS=0x...

# RPC Provider
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CHAIN_ID=11155111
NETWORK=sepolia

# ==========================================
# RELAYER CONFIGURATION
# ==========================================

# Relayer wallet address (who submits batches)
RELAYER_ADDRESS=0x...

# Relayer private key (for signing transactions)
# WARNING: Never commit real private key to git!
RELAYER_PRIVATE_KEY=0x...

# Max gas price (in gwei)
MAX_GAS_PRICE=100

# ==========================================
# BATCH SETTLEMENT
# ==========================================

# Batch timeout (duration string: 5m, 300s)
BATCH_TIMEOUT=5m

# Batch size (number of transactions)
BATCH_SIZE=10

# Max retries for failed batch
MAX_BATCH_RETRIES=3

# ==========================================
# BALANCE SYNCHRONIZATION
# ==========================================

# Sync interval from blockchain (duration string)
SYNC_INTERVAL=10m

# Force full sync every N syncs
FULL_SYNC_FREQUENCY=12

# ==========================================
# RATE LIMITING
# ==========================================

# Requests per minute per user
RATE_LIMIT_PER_MINUTE=100

# Requests per minute per IP
RATE_LIMIT_PER_IP=1000

# ==========================================
# LOGGING
# ==========================================

# Log level: debug | info | warn | error | fatal
LOG_LEVEL=info

# Log file path (leave empty for stdout only)
LOG_FILE=./logs/app.log

# Max log file size in MB (before rotation)
LOG_MAX_SIZE=100

# Max backup log files to keep
LOG_MAX_BACKUP=5

# ==========================================
# JWT AUTHENTICATION (Optional)
# ==========================================

JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRY=24h

# ==========================================
# ADMIN CREDENTIALS
# ==========================================

# Admin token for sensitive endpoints
ADMIN_TOKEN=your_admin_token_here

# ==========================================
# CORS CONFIGURATION
# ==========================================

# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.vndc.io

# ==========================================
# WEBHOOK CONFIGURATION (Optional)
# ==========================================

# Enable webhooks for transaction status changes
WEBHOOK_ENABLED=false

# Retry policy for failed webhooks
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=1m

# ==========================================
# BLOCKCHAIN CONFIRMATION
# ==========================================

# Required block confirmations before marking settlement as final
REQUIRED_CONFIRMATIONS=12

# Polling interval for confirmations
CONFIRMATION_CHECK_INTERVAL=30s

# ==========================================
# FEATURE FLAGS
# ==========================================

# Enable/disable features
FEATURE_NFT_MINTING=true
FEATURE_BATCH_SETTLEMENT=true
FEATURE_BALANCE_SYNC=true
FEATURE_WEBHOOK=false

# ==========================================
# EXTERNAL SERVICES (Optional)
# ==========================================

# Sentry for error tracking
SENTRY_DSN=

# Slack for notifications
SLACK_WEBHOOK_URL=

# PagerDuty for alerting
PAGERDUTY_KEY=

# ==========================================
# TESTING
# ==========================================

# Use test database
USE_TEST_DB=false

# Reset database on startup
RESET_DB_ON_START=false
