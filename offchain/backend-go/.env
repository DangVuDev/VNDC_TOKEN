# VNDC backend local environment

# Optional. Defaults to config/config.yaml when omitted.
CONFIG_PATH=config/config.yaml

# Database
APP_DATABASE_URI=mongodb://localhost:27017

# Auth
APP_AUTH_ADMIN_TOKEN=your_admin_token_here
APP_AUTH_SIWE_DOMAIN=localhost

# Local chain signer keys. Dev-only Hardhat accounts.
APP_BLOCKCHAIN_LOCAL_RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
APP_BLOCKCHAIN_LOCAL_TASK_MANAGER_SIGNER_PRIV_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Sepolia signer keys. Fill these only when deploying/running against Sepolia.
APP_BLOCKCHAIN_SEPOLIA_RELAYER_PRIVATE_KEY=
APP_BLOCKCHAIN_SEPOLIA_TASK_MANAGER_SIGNER_PRIV_KEY=

# Ethereum mainnet signer keys. Keep empty unless mainnet contracts are ready.
APP_BLOCKCHAIN_ETHEREUM_RELAYER_PRIVATE_KEY=
APP_BLOCKCHAIN_ETHEREUM_TASK_MANAGER_SIGNER_PRIV_KEY=
