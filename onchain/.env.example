# Environment Variables for On-Chain (Hardhat)

# RPC Providers
# Infura
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Or Alchemy
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Or QuickNode
# SEPOLIA_RPC_URL=https://eth-sepolia.quiknode.pro/YOUR_ENDPOINT

# Deployer Account Private Key
# WARNING: Never commit real private key to git!
# Use test account for development only
PRIVATE_KEY=0x...

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Network Configuration
CHAIN_ID=11155111
NETWORK=sepolia
